                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Review retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Review"
                }
              }
            }
          },
          "400": {
            "description": "Review wasn't retrieved"
          }
        }
      },
      "delete": {
        "summary": "Delete a review by its reviewID",
        "tags": [
          "Reviews"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "reviewId",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the review to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Review deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Review deleted successfully"
                    },
                    "data": {
                      "type": "string",
                      "description": "The ID of the deleted review",
                      "example": "REV-2025-01"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Review couldn't be deleted"
          }
        }
      }
    },
    "/reviews/{reviewid}": {
      "put": {
        "summary": "Update an existing review",
        "tags": [
          "Reviews"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "reviewId",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the review to update"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "reviewOutOfTen"
                ],
                "properties": {
                  "reviewOutOfTen": {
                    "type": "number",
                    "description": "Updated score for the review (0–10)",
                    "example": 9
                  },
                  "comments": {
                    "type": "string",
                    "description": "Optional updated comments",
                    "example": "The course improved a lot this term."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Review info updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Review"
                }
              }
            }
          },
          "400": {
            "description": "Review info couldn't be updated"
          }
        }
      }
    },
    "/sections": {
      "post": {
        "summary": "Create a new section",
        "tags": [
