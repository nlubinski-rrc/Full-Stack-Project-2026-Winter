                    "example": "Dr. Smith"
                  },
                  "capacity": {
                    "type": "number",
                    "description": "Maximum number of students allowed in this section",
                    "example": 30
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Section created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Section"
                }
              }
            }
          },
          "400": {
