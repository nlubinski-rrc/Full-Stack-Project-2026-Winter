                "properties": {
                  "location": {
                    "type": "string",
                    "description": "Updated location for the section",
                    "example": "Room 205"
                  },
                  "capacity": {
                    "type": "number",
                    "description": "Updated capacity for the section",
                    "example": 35
                  },
                  "teacher": {
                    "type": "string",
                    "description": "Updated teacher for the section",
                    "example": "Mr. larry"
                  }
