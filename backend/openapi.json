                  "capacity"
                ],
                "properties": {
                  "sectionId": {
                    "type": "string",
                    "description": "Unique identifier for the section",
                    "example": "SEC-101-A"
                  },
                  "location": {
                    "type": "string",
                    "description": "The location where this section is held",
                    "example": "Room 204"
                  },
                  "teacher": {
                    "type": "string",
