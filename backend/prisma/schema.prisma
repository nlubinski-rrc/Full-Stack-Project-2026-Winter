generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  url = env("DATABASE_URL")
  provider = "postgresql"
}

model Review {
  Id Int @id @default(autoincrement())
  movieName String
  review String
  reviewOutOfTen Int
  movie Movie @relation(fields: [movieName], references: [title])
}

model Movie {
  id Int @id @default(autoincrement())
  title String @unique
  overview String
  averageRating Int
  releaseDate String
  wishlists Watchlist[]
  reviews Review[]
  movieActors Actor[]
}

model Watchlist {
  Id Int @id @default(autoincrement())
  userId String
  User User @relation(fields: [userId], references: [id])
  movieId Int
  movie Movie @relation(fields: [movieId], references: [id])
}

model Actor {
  id Int @id @default(autoincrement())
  name String
  isFavourite Boolean
  actorMovies Movie[]
}

model User {
  id        String @id
  watchlist Watchlist[]
}

